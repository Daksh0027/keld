 .blueprint-district {
   position: absolute;
-  cursor: pointer;
+  cursor: crosshair;
   border: 1px solid #2a2a2a;
   transition: all 0.2s ease;
+  opacity: 0;
+  animation: flicker-in 0.8s forwards;
+}
+
+@keyframes flicker-in {
+  0% { opacity: 0; }
+  10% { opacity: 0.5; }
+  20% { opacity: 0; }
+  30% { opacity: 0.8; }
+  40% { opacity: 0.2; }
+  50% { opacity: 1; }
+  60% { opacity: 0.4; }
+  100% { opacity: 1; }
 }
+
+.d1 { animation-delay: 0.2s; }
+.d2 { animation-delay: 0.6s; }
+.d3 { animation-delay: 1.1s; }
+.d4 { animation-delay: 1.5s; }
+.d5 { animation-delay: 2.2s; }
+.d6 { animation-delay: 2.8s; }
+.d7 { animation-delay: 3.2s; }
+.d8 { animation-delay: 3.5s; }
 
 .blueprint-district:hover {
